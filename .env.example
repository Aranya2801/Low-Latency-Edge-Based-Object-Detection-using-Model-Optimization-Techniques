# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-secret-key-in-production-min-64-chars

# ── Inference Device ─────────────────────────────────────────────────────────
DEVICE=auto        # auto | cpu | cuda:0 | mps
DEFAULT_MODEL=yolov8n
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45
INPUT_SIZE=640
DETECTION_MODE=all

# ── Tracking ─────────────────────────────────────────────────────────────────
ENABLE_TRACKING=true
TRACKER=bytetrack

# ── Alerts ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SENDGRID_API_KEY=
ALERT_EMAIL=

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///./mlflow.db
MLFLOW_EXPERIMENT_NAME=edge-ai-detection
